# ── Database ──────────────────────────────────────────────────────────────────
# For Supabase: Dashboard → Project Settings → Database → Connection string → Python
# Replace [project-ref] and [password] with your actual values.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# For local development (SQLite, no Supabase needed):
# DATABASE_URL=sqlite:///mana.db

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-32-char-secret
